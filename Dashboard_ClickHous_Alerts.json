{"version":"0.1.0","name":"ClickHouse Alerts","tiles":[{"id":"18dlwy","x":0,"y":0,"w":24,"h":13,"config":{"name":"","source":"ClickHouse Cloud Query Logs","displayType":"line","granularity":"auto","alignDateRangeToGranularity":true,"select":[{"aggFn":"quantile","level":0.99,"aggCondition":"query_kind = 'Select'  AND (type = 'ExceptionWhileProcessing' OR type = 'QueryFinish')","aggConditionLanguage":"sql","valueExpression":"query_duration_ms","alias":"p99"},{"aggFn":"quantile","level":0.95,"aggCondition":"query_kind = 'Select'  AND (type = 'ExceptionWhileProcessing' OR type = 'QueryFinish')","aggConditionLanguage":"sql","valueExpression":"query_duration_ms","alias":"p95"},{"aggFn":"none","aggCondition":"","aggConditionLanguage":"lucene","valueExpression":"quantileIf (0.5) (\n    toFloat64OrDefault(toString(query_duration_ms)),\n    query_kind = 'Select'\n    AND (\n      type\n        = 'ExceptionWhileProcessing'\n        OR\n      type\n        = 'QueryFinish'\n    )\n    AND toFloat64OrDefault(toString(query_duration_ms)) IS NOT NULL\n  )","alias":"p50"}],"where":"","whereLanguage":"lucene"}},{"id":"a83xb","x":0,"y":13,"w":24,"h":14,"config":{"name":"Query Count by Table","source":"ClickHouse Cloud Query Logs","displayType":"line","granularity":"auto","alignDateRangeToGranularity":true,"select":[{"aggFn":"count","aggCondition":"query_kind = 'Select' AND (type = 'ExceptionWhileProcessing' OR type = 'QueryFinish' OR type = 'ExceptionBeforeStart')","aggConditionLanguage":"sql","valueExpression":""}],"where":"","whereLanguage":"lucene","groupBy":"tables, type"}},{"id":"lp3qa","x":0,"y":27,"w":24,"h":11,"config":{"displayType":"table","granularity":"auto","alignDateRangeToGranularity":true,"configType":"sql","sqlTemplate":"SELECT\n  count()                               AS \"Count\",\n  sum(query_duration_ms)                AS \"Total Duration (ms)\",\n  any(query)                            AS \"Query Example\",\n  normalized_query_hash                 AS \"Query Hash\